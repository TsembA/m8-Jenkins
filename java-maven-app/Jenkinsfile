def gv

pipeline {   
    agent any
    tools {
        maven 'Maven'
    }
    stages {
        stage("init") {
            }
            steps {
                dir('java-maven-app') {
                    script {
                        gv = load "script.groovy"
                    }
                }
            }
        }

        stage("build jar") {
            }
            steps {
                dir('java-maven-app') {
                    script {
                        buildJar()
                    }
                }
            }
        }

        stage("build image") {
            }
            steps {
                dir('java-maven-app') {
                    script {
                        buildImage()
                    }
                }
            }
        }

        stage("deploy") {
            }
            steps {
                dir('java-maven-app') {
                    script {
                        deployApp()
                    }
                }
            }
        }               
    }
}
