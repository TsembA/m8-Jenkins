pipeline {
    agent any
    tools {
        maven 'Maven'
    }

    stages {
        stage('init') {
            steps {
                script {
                    gv = load "script.groovy"
                }
            }
        }

        stage('build jar') {
            steps {
                dir('java-maven-app') {
                    script {
                        buildjar()
                    }
                }
            }
        }

        stage('build images') {
            steps {
                dir('java-maven-app') {
                    script {
                        buildImage()
                    }
                }
            }
        }
    }
}
